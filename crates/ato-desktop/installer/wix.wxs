<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ato Desktop — Windows MSI installer (WiX 3.x).

  Used by xtask bundle for the windows-x86_64 msi target.
  See package_msi() for the candle/light invocation; the
  `$(var.StagingDir)` and `$(var.ProductVersion)` placeholders are
  injected from xtask.

  Layout produced:
    Program Files\Ato\
      ato-desktop.exe
      bin\ato.exe
      assets\...

  Side effects:
    - bin\ appended to user PATH (so `ato` resolves in cmd/PowerShell)
    - HKCU\Software\Classes\ato     URL Protocol
    - HKCU\Software\Classes\capsule URL Protocol
    - Start Menu shortcut to ato-desktop.exe
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Product Id="*"
           Name="Ato Desktop"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="ato-run"
           UpgradeCode="6F8B4A4D-5E6C-4F1B-9A8C-2C3D4E5F6A7B">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Ato Desktop installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Ato Desktop is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Complete" Title="Ato Desktop" Level="1">
      <ComponentGroupRef Id="AtoFiles" />
      <ComponentRef Id="UrlSchemeAto" />
      <ComponentRef Id="UrlSchemeCapsule" />
      <ComponentRef Id="PathEntry" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Ato">
          <Directory Id="BinFolder" Name="bin" />
          <Directory Id="AssetsFolder" Name="assets" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Ato Desktop" />
      </Directory>
    </Directory>

    <ComponentGroup Id="AtoFiles" Directory="INSTALLFOLDER">
      <Component Id="DesktopExe" Guid="*">
        <File Id="AtoDesktopExe"
              Source="$(var.StagingDir)\ato-desktop.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="HelperExe" Guid="*" Directory="BinFolder">
        <File Id="AtoExe"
              Source="$(var.StagingDir)\bin\ato.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- bin\ on PATH so command-line invocations of `ato` work. -->
    <Component Id="PathEntry" Directory="BinFolder" Guid="2C7B8E5F-3F4A-4B5C-9D8E-1A2B3C4D5E6F">
      <CreateFolder />
      <Environment Id="AtoPath"
                   Name="PATH"
                   Action="set"
                   System="yes"
                   Part="last"
                   Permanent="no"
                   Value="[BinFolder]" />
    </Component>

    <Component Id="UrlSchemeAto" Directory="INSTALLFOLDER" Guid="2D3F4E5C-1B2A-4D5E-8C9F-3A4B5C6D7E8F">
      <CreateFolder />
      <RegistryKey Root="HKCU" Key="Software\Classes\ato">
        <RegistryValue Type="string" Value="URL:ato Protocol" />
        <RegistryValue Name="URL Protocol" Type="string" Value="" />
      </RegistryKey>
      <RegistryKey Root="HKCU" Key="Software\Classes\ato\shell\open\command">
        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]ato-desktop.exe&quot; &quot;%1&quot;" />
      </RegistryKey>
    </Component>

    <Component Id="UrlSchemeCapsule" Directory="INSTALLFOLDER" Guid="3E4F5A6B-2C3D-4E5F-9A0B-4C5D6E7F8A9B">
      <CreateFolder />
      <RegistryKey Root="HKCU" Key="Software\Classes\capsule">
        <RegistryValue Type="string" Value="URL:capsule Protocol" />
        <RegistryValue Name="URL Protocol" Type="string" Value="" />
      </RegistryKey>
      <RegistryKey Root="HKCU" Key="Software\Classes\capsule\shell\open\command">
        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]ato-desktop.exe&quot; &quot;%1&quot;" />
      </RegistryKey>
    </Component>

    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="4F5A6B7C-3D4E-5F6A-0B1C-5D6E7F8A9B0C">
      <Shortcut Id="AtoDesktopShortcut"
                Name="Ato Desktop"
                Description="Capsule runner"
                Target="[INSTALLFOLDER]ato-desktop.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\ato-run\AtoDesktop"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Product>
</Wix>
