---
// Featured apps section with 3 app cards 
---
<div>
  <div class="flex items-center justify-between px-1 mb-4">
    <div class="flex items-center gap-2 text-[14px] font-bold text-slate-800">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 008.5 14.063l-6.135-1.582a.5.5 0 010-.962L8.5 9.936A2 2 0 009.937 8.5l1.582-6.135a.5.5 0 01.963 0L14.063 8.5A2 2 0 0015.5 9.937l6.135 1.581a.5.5 0 010 .964L15.5 14.063a2 2 0 00-1.437 1.437l-1.582 6.135a.5.5 0 01-.963 0z"/></svg>
      Featured Apps
    </div>
    <button class="section-link text-[11px] font-bold text-rose-500 flex items-center gap-1 hover:text-rose-600 transition-colors" data-action="view_all_store">
      View all in store
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </button>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div class="p-4 rounded-2xl border border-slate-100 bg-white shadow-sm flex gap-3 hover:shadow-md transition-shadow cursor-pointer featured-card" data-action="open_capsule" data-handle="capsule://affine">
      <div class="w-[72px] h-[72px] rounded-2xl bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center shrink-0 shadow-inner relative overflow-hidden">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linejoin="round" class="w-8 h-8 opacity-90">
          <path d="M12 2L2 20h20L12 2z" />
          <path d="M12 10l-4 7h8l-4-7z" />
          <circle cx="12" cy="5" r="1.5" fill="white" stroke="none" />
          <circle cx="5" cy="18" r="1.5" fill="white" stroke="none" />
          <circle cx="19" cy="18" r="1.5" fill="white" stroke="none" />
        </svg>
      </div>
      <div class="flex flex-col flex-1 h-full py-0.5">
        <div class="flex items-center gap-2 mb-0.5">
          <h4 class="font-bold text-[#0F172A] text-[13px]">AFFINE</h4>
          <span class="text-[9px] font-bold text-rose-500 bg-rose-50 px-1.5 py-0.5 rounded-md">Store</span>
        </div>
        <p class="text-[10px] text-slate-500 leading-[1.35] mb-auto">The open-source workspace for note-taking and knowledge.</p>
        <div class="flex items-center justify-between mt-2">
          <div class="flex items-center gap-1 text-[10px] text-slate-500 font-medium">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1" class="shrink-0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="text-slate-700">4.7</span>
            <span class="opacity-40 px-0.5">&#8226;</span>
            <span class="flex items-center gap-0.5">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              2.1k
            </span>
          </div>
          <button class="featured-launch flex items-center gap-1 bg-gradient-to-r from-[#FF905A] to-[#F43F5E] text-white px-2.5 py-1.5 rounded-lg text-[10px] font-bold shadow-sm hover:opacity-90">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Launch
          </button>
        </div>
      </div>
    </div>

    <div class="p-4 rounded-2xl border border-slate-100 bg-white shadow-sm flex gap-3 hover:shadow-md transition-shadow cursor-pointer featured-card" data-action="open_capsule" data-handle="capsule://open-webui">
      <div class="w-[72px] h-[72px] rounded-2xl bg-[#0F172A] flex items-center justify-center shrink-0 shadow-inner">
        <div class="text-white font-bold text-[28px] tracking-tighter leading-none">OI</div>
      </div>
      <div class="flex flex-col flex-1 h-full py-0.5">
        <div class="flex items-center gap-2 mb-0.5">
          <h4 class="font-bold text-[#0F172A] text-[13px]">Open WebUI</h4>
          <span class="text-[9px] font-bold text-rose-500 bg-rose-50 px-1.5 py-0.5 rounded-md">Store</span>
        </div>
        <p class="text-[10px] text-slate-500 leading-[1.35] mb-auto">Self-hosted AI interface for LLMs that just works.</p>
        <div class="flex items-center justify-between mt-2">
          <div class="flex items-center gap-1 text-[10px] text-slate-500 font-medium">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1" class="shrink-0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="text-slate-700">4.8</span>
            <span class="opacity-40 px-0.5">&#8226;</span>
            <span class="flex items-center gap-0.5">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              3.3k
            </span>
          </div>
          <button class="featured-launch flex items-center gap-1 bg-gradient-to-r from-[#FF905A] to-[#F43F5E] text-white px-2.5 py-1.5 rounded-lg text-[10px] font-bold shadow-sm hover:opacity-90">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Launch
          </button>
        </div>
      </div>
    </div>

    <div class="p-4 rounded-2xl border border-slate-100 bg-white shadow-sm flex gap-3 hover:shadow-md transition-shadow cursor-pointer featured-card" data-action="open_capsule" data-handle="capsule://excalidraw">
      <div class="w-[72px] h-[72px] rounded-2xl bg-gradient-to-br from-pink-400 to-rose-500 flex items-center justify-center shrink-0 shadow-inner">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 opacity-90">
          <rect x="5" y="5" width="14" height="14" rx="2" transform="rotate(45 12 12)" />
          <path d="M9 9l6 6M15 9l-6 6" />
        </svg>
      </div>
      <div class="flex flex-col flex-1 h-full py-0.5">
        <div class="flex items-center gap-2 mb-0.5">
          <h4 class="font-bold text-[#0F172A] text-[13px]">Excalidraw</h4>
          <span class="text-[9px] font-bold text-rose-500 bg-rose-50 px-1.5 py-0.5 rounded-md">Store</span>
        </div>
        <p class="text-[10px] text-slate-500 leading-[1.35] mb-auto">Virtual whiteboard for sketching diagrams and ideas.</p>
        <div class="flex items-center justify-between mt-2">
          <div class="flex items-center gap-1 text-[10px] text-slate-500 font-medium">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1" class="shrink-0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="text-slate-700">4.6</span>
            <span class="opacity-40 px-0.5">&#8226;</span>
            <span class="flex items-center gap-0.5">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              1.6k
            </span>
          </div>
          <button class="featured-launch flex items-center gap-1 bg-gradient-to-r from-[#FF905A] to-[#F43F5E] text-white px-2.5 py-1.5 rounded-lg text-[10px] font-bold shadow-sm hover:opacity-90">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Launch
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
