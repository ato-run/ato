---
// 4 action cards: Run any repo, Open local app, Browse store, New workspace 
---
<div class="grid grid-cols-4 gap-4 mb-8">
  <div class="action-card flex flex-col p-4 rounded-2xl border border-rose-100 bg-rose-50/30 shadow-sm cursor-pointer hover:shadow-md transition-all hover:-translate-y-0.5 group" data-action="github">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-12 h-12 rounded-[14px] bg-gradient-to-br from-rose-400 to-rose-500 text-white flex items-center justify-center shadow-inner shrink-0 group-hover:scale-105 transition-transform">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
      </div>
      <div class="mt-1">
        <h3 class="font-bold text-[14px] text-[#0F172A]">Run any repo</h3>
        <p class="text-[11px] text-slate-500 leading-tight mt-0.5">Launch directly from source</p>
      </div>
    </div>
    <div class="mt-auto">
      <span class="inline-flex items-center gap-1 text-[10px] font-bold text-slate-600 bg-white border border-slate-200 px-2 py-1 rounded-md shadow-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="#334155" class="shrink-0"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
        GitHub
      </span>
    </div>
  </div>

  <div class="action-card flex flex-col p-4 rounded-2xl border border-amber-100 bg-amber-50/30 shadow-sm cursor-pointer hover:shadow-md transition-all hover:-translate-y-0.5 group" data-action="local">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-12 h-12 rounded-[14px] bg-gradient-to-br from-amber-400 to-orange-400 text-white flex items-center justify-center shadow-inner shrink-0 group-hover:scale-105 transition-transform">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 002-2V8a2 2 0 00-2-2h-7.93a2 2 0 01-1.66-.9l-.82-1.2A2 2 0 007.93 3H4a2 2 0 00-2 2v13c0 1.1.9 2 2 2z"/></svg>
      </div>
      <div class="mt-1">
        <h3 class="font-bold text-[14px] text-[#0F172A]">Open local app</h3>
        <p class="text-[11px] text-slate-500 leading-tight mt-0.5">Run a folder, file, or project</p>
      </div>
    </div>
    <div class="mt-auto">
      <span class="inline-flex items-center gap-1 text-[10px] font-bold text-slate-600 bg-white border border-slate-200 px-2 py-1 rounded-md shadow-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 002-2V8a2 2 0 00-2-2h-7.93a2 2 0 01-1.66-.9l-.82-1.2A2 2 0 007.93 3H4a2 2 0 00-2 2v13c0 1.1.9 2 2 2z"/></svg>
        Local
      </span>
    </div>
  </div>

  <div class="action-card flex flex-col p-4 rounded-2xl border border-blue-100 bg-blue-50/30 shadow-sm cursor-pointer hover:shadow-md transition-all hover:-translate-y-0.5 group" data-action="store">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-12 h-12 rounded-[14px] bg-gradient-to-br from-blue-400 to-blue-500 text-white flex items-center justify-center shadow-inner shrink-0 group-hover:scale-105 transition-transform">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </div>
      <div class="mt-1">
        <h3 class="font-bold text-[14px] text-[#0F172A]">Browse store</h3>
        <p class="text-[11px] text-slate-500 leading-tight mt-0.5">Discover apps and capsules</p>
      </div>
    </div>
    <div class="mt-auto">
      <span class="inline-flex items-center gap-1 text-[10px] font-bold text-blue-600 bg-blue-50 border border-blue-100 px-2 py-1 rounded-md shadow-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Store
      </span>
    </div>
  </div>

  <div class="flex flex-col p-4 rounded-2xl border border-slate-100 bg-slate-50/80 shadow-sm cursor-default opacity-50">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-12 h-12 rounded-[14px] bg-slate-100 text-slate-400 flex items-center justify-center border border-slate-200 shrink-0">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
      <div class="mt-1">
        <h3 class="font-bold text-[14px] text-[#0F172A]">New workspace</h3>
        <p class="text-[11px] text-slate-500 leading-tight mt-0.5">Optional</p>
      </div>
    </div>
    <div class="mt-auto">
      <span class="inline-flex items-center gap-1 text-[10px] font-bold text-purple-500 bg-purple-50 border border-purple-100 px-2 py-1 rounded-md shadow-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Coming soon
      </span>
    </div>
  </div>
</div>
