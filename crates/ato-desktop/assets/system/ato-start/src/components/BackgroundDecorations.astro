---
// Orbit rings + twinkling stars decorative background
// Transforms match the original app.tsx: each ring has a unique Y-rotation
// and Z-translation so they form a 3D tunnel when the wrapper rotates.
---
<div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
  <div class="orbit-container">
    <div class="orbit-wrapper">
      <div class="orbit-ring" style="transform: rotateY(0deg) translateZ(120px);"></div>
      <div class="orbit-ring" style="transform: rotateY(60deg) translateZ(96px);"></div>
      <div class="orbit-ring" style="transform: rotateY(120deg) translateZ(72px);"></div>
      <div class="orbit-ring" style="transform: rotateY(180deg) translateZ(48px);"></div>
      <div class="orbit-ring" style="transform: rotateY(240deg) translateZ(24px);"></div>
      <div class="orbit-ring" style="transform: rotateY(300deg) translateZ(0px);"></div>
    </div>
  </div>

  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="absolute top-20 left-[20%] text-amber-300 opacity-80 animate-pulse3">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="absolute top-16 right-[25%] text-rose-300 opacity-60 animate-pulse4">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>
  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="absolute top-40 right-[15%] text-purple-300 opacity-70 animate-pulse2-5">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="absolute top-[30%] left-[10%] text-blue-300 opacity-60 animate-pulse3-5">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>

  <svg class="absolute top-[25%] right-[35%] w-4 h-4 text-emerald-300 opacity-60 animate-pulse3" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 0L14 10L24 12L14 14L12 24L10 14L0 12L10 10Z" />
  </svg>
  <svg class="absolute top-[15%] left-[35%] w-3 h-3 text-rose-400 opacity-50 animate-pulse2" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 0L14 10L24 12L14 14L12 24L10 14L0 12L10 10Z" />
  </svg>
</div>

<style is:global>
  .orbit-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    transform-style: preserve-3d;
    z-index: 0;
    pointer-events: none;
    perspective: 1000px;
  }
  .orbit-wrapper {
    width: 540px;
    height: 540px;
    animation: orbitRotation 30s linear infinite;
    transform-style: preserve-3d;
    position: absolute;
    top: 50%;
    left: 50%;
    margin-top: -270px;
    margin-left: -270px;
    transform-origin: center center;
  }
  .orbit-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border-width: 1px;
    border-style: solid;
    transform-style: preserve-3d;
    transform-origin: center center;
    animation: orbitColorLoop 15s linear infinite;
  }
  @keyframes orbitRotation {
    from { transform: rotateY(0deg) rotateX(30deg); }
    to { transform: rotateY(360deg) rotateX(30deg); }
  }
  @keyframes orbitColorLoop {
    0%   { border-color: rgba(244, 63, 94, 0.25); }
    25%  { border-color: rgba(167, 139, 250, 0.25); }
    50%  { border-color: rgba(56, 189, 248, 0.25); }
    75%  { border-color: rgba(251, 191, 36, 0.25); }
    100% { border-color: rgba(244, 63, 94, 0.25); }
  }
  @keyframes pulse2 { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  @keyframes pulse2-5 { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  @keyframes pulse3 { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  @keyframes pulse3-5 { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  @keyframes pulse4 { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .animate-pulse2 { animation: pulse2 2s ease-in-out infinite; }
  .animate-pulse2-5 { animation: pulse2-5 2.5s ease-in-out infinite; }
  .animate-pulse3 { animation: pulse3 3s ease-in-out infinite; }
  .animate-pulse3-5 { animation: pulse3-5 3.5s ease-in-out infinite; }
  .animate-pulse4 { animation: pulse4 4s ease-in-out infinite; }
</style>
