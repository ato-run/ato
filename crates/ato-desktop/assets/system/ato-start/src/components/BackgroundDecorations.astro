---
// Orbit rings + twinkling stars decorative background
// Transforms match the original app.tsx: each ring has a unique Y-rotation
// and Z-translation so they form a 3D tunnel when the wrapper rotates.
---
<div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
  <div class="orbit-container">
    <div class="orbit-wrapper">
      <div class="orbit-ring" style="transform: rotateY(0deg) translateZ(120px);"></div>
      <div class="orbit-ring" style="transform: rotateY(60deg) translateZ(96px);"></div>
      <div class="orbit-ring" style="transform: rotateY(120deg) translateZ(72px);"></div>
      <div class="orbit-ring" style="transform: rotateY(180deg) translateZ(48px);"></div>
      <div class="orbit-ring" style="transform: rotateY(240deg) translateZ(24px);"></div>
      <div class="orbit-ring" style="transform: rotateY(300deg) translateZ(0px);"></div>
    </div>
  </div>
</div>

<style is:global>
  .orbit-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    transform-style: preserve-3d;
    z-index: 0;
    pointer-events: none;
    perspective: 1000px;
  }
  .orbit-wrapper {
    width: 540px;
    height: 540px;
    animation: orbitRotation 30s linear infinite;
    transform-style: preserve-3d;
    position: absolute;
    top: 50%;
    left: 50%;
    margin-top: -270px;
    margin-left: -270px;
    transform-origin: center center;
  }
  .orbit-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border-width: 1px;
    border-style: solid;
    transform-style: preserve-3d;
    transform-origin: center center;
    animation: orbitColorLoop 15s linear infinite;
  }
  @keyframes orbitRotation {
    from { transform: rotateY(0deg) rotateX(30deg); }
    to { transform: rotateY(360deg) rotateX(30deg); }
  }
  @keyframes orbitColorLoop {
    0%   { border-color: rgba(244, 63, 94, 0.25); }
    25%  { border-color: rgba(167, 139, 250, 0.25); }
    50%  { border-color: rgba(56, 189, 248, 0.25); }
    75%  { border-color: rgba(251, 191, 36, 0.25); }
    100% { border-color: rgba(244, 63, 94, 0.25); }
  }
  
</style>
