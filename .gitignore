# Rust build artifacts
target/
**/*.rs.bk
**/*.rmeta

# macOS
.DS_Store
.AppleDouble
.LSOverride
**/.DS_Store

# Editors / IDEs
*.swp
*~
.idea/
# (`.vscode/` is intentionally tracked — see committed `.vscode/settings.json`.)

# Local-only Claude Code overrides — shared config lives in `.claude/settings.json`
.claude/settings.local.json
.claude/.cache/
.claude/scheduled_tasks.lock

# Local sandbox dir for samples scratch work
samples/tutorial/

# Serena semantic index (machine-local cache)
.serena/

# Cloudflare Wrangler local state
.wrangler/

# Local scratch / runtime artifacts
.tmp/
.ato/
**/.ato/
**/node_modules/
**/.next/
**/dist/

# Parallel-development worktrees (see CLAUDE.md → "Parallel development with git worktrees").
# The directory itself is tracked via .worktrees/.gitkeep so it always exists
# after clone; everything else inside is host-local.
.worktrees/*
!.worktrees/.gitkeep

# Test artifacts (generated on every run)
tests/manual/results/
tests/test-sandbox/output/

# Logs
*.log

# Generated specs / lockfiles that should be reproducible from sources
# (Cargo.lock IS committed in this workspace — application repo, not library.)


