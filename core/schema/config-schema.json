{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://capsuled.dev/schema/config/v1.0.0",
  "title": "Nacelle Runtime Configuration",
  "description": "Low-level execution configuration for nacelle runtime. Generated by ato-cli during pack phase. Inspired by OCI Runtime Spec (config.json) but optimized for a services-first execution model.",
  "type": "object",
  "required": ["version", "services", "sandbox"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version (semantic versioning)",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "default": "1.0.0"
    },
    "services": {
      "type": "object",
      "description": "Service definitions (single process uses services.main)",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["executable", "args"],
        "properties": {
          "executable": {
            "type": "string",
            "description": "Absolute or bundle-relative path to the executable (e.g., 'runtime/python/bin/python3', 'source/main.wasm')"
          },
          "args": {
            "type": "array",
            "description": "Command-line arguments (argv). First element is typically the script/module to run.",
            "items": {
              "type": "string"
            },
            "minItems": 0
          },
          "cwd": {
            "type": "string",
            "description": "Working directory (absolute or bundle-relative). Defaults to 'source'.",
            "default": "source"
          },
          "env": {
            "type": "object",
            "description": "Environment variables (KEY=VALUE). Pre-resolved by ato-cli.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "user": {
            "type": "object",
            "description": "User context for process execution (POSIX)",
            "properties": {
              "uid": {
                "type": "integer",
                "description": "User ID",
                "minimum": 0
              },
              "gid": {
                "type": "integer",
                "description": "Group ID",
                "minimum": 0
              },
              "umask": {
                "type": "integer",
                "description": "File mode creation mask (octal)",
                "minimum": 0,
                "maximum": 511
              }
            }
          },
          "signals": {
            "type": "object",
            "description": "Signal handling configuration",
            "properties": {
              "stop": {
                "type": "string",
                "description": "Signal for graceful shutdown",
                "default": "SIGTERM"
              },
              "kill": {
                "type": "string",
                "description": "Signal for force kill",
                "default": "SIGKILL"
              }
            }
          },
          "depends_on": {
            "type": "array",
            "description": "Service dependencies (must start after these services)",
            "items": {
              "type": "string"
            }
          },
          "health_check": {
            "type": "object",
            "description": "Health/readiness check",
            "properties": {
              "http_get": {
                "type": "string",
                "description": "HTTP endpoint (e.g., '/health')"
              },
              "tcp_connect": {
                "type": "string",
                "description": "TCP host (default: 127.0.0.1)"
              },
              "port": {
                "type": "string",
                "description": "Port number or placeholder name (resolved by ato-cli)"
              },
              "interval_secs": {
                "type": "integer",
                "description": "Check interval in seconds",
                "minimum": 1,
                "default": 5
              },
              "timeout_secs": {
                "type": "integer",
                "description": "Check timeout in seconds",
                "minimum": 1,
                "default": 3
              }
            }
          },
          "ports": {
            "type": "object",
            "description": "Port allocations (KEY = placeholder name, VALUE = allocated port)",
            "additionalProperties": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "description": "OS-native sandbox configuration (Landlock/Seatbelt)",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether sandbox is enabled",
          "default": true
        },
        "filesystem": {
          "type": "object",
          "description": "Filesystem access policy",
          "properties": {
            "read_only": {
              "type": "array",
              "description": "Paths allowed for read-only access (e.g., ['/usr', '/lib', 'runtime'])",
              "items": {
                "type": "string"
              }
            },
            "read_write": {
              "type": "array",
              "description": "Paths allowed for read-write access (e.g., ['source', '/tmp'])",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "network": {
          "type": "object",
          "description": "Network access policy",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether network access is allowed",
              "default": true
            },
            "enforcement": {
              "type": "string",
              "enum": ["strict", "best_effort"],
              "description": "strict: Requires Root/CAP_BPF & cgroup v2. Fails if unmet. best_effort: Logs warning and allows traffic if privileges/features are missing.",
              "default": "best_effort"
            },
            "egress": {
              "type": "object",
              "description": "Egress (outbound) policy",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["allow_all", "deny_all", "allowlist"],
                  "description": "Egress policy mode",
                  "default": "allow_all"
                },
                "rules": {
                  "type": "array",
                  "description": "Egress allowlist (IP/CIDR). Domains should be listed in allow_domains.",
                  "items": {
                    "type": "object",
                    "required": ["type", "value"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["ip", "cidr"],
                        "description": "Rule type"
                      },
                      "value": {
                        "type": "string",
                        "description": "Rule value (e.g., '1.1.1.1', '10.0.0.0/8')"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "development_mode": {
          "type": "boolean",
          "description": "More permissive sandbox for development (not recommended for production)",
          "default": false
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata for debugging and auditing",
      "properties": {
        "name": {
          "type": "string",
          "description": "Capsule name"
        },
        "version": {
          "type": "string",
          "description": "Capsule version"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when config.json was generated (ISO 8601)"
        },
        "generated_by": {
          "type": "string",
          "description": "Tool that generated this config (e.g., 'ato-cli v0.3.0')"
        },
        "source_manifest": {
          "type": "string",
          "description": "Original capsule.toml digest (SHA256) for traceability"
        }
      }
    },
    "annotations": {
      "type": "object",
      "description": "Arbitrary key-value metadata (OCI-compatible)",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
