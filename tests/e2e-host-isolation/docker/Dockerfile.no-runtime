# syntax=docker/dockerfile:1
# Tester-only image for Test 01: no-runtime environment.
#
# Unlike Dockerfile.no-runtime-e2e (which compiles from source), this image
# expects the ato binary to be injected at /usr/local/bin/ato at docker run
# time via a bind mount. It contains no Node, Python, npm, or any managed
# runtime — only the minimal tools needed to run the test harness.
#
# Usage (from the e2e-host-isolation workflow):
#   docker run --rm \
#     -v /path/to/ato:/usr/local/bin/ato:ro \
#     -v $(pwd)/tests:/tests:ro \
#     ghcr.io/ato-run/ato-no-runtime-tester \
#     bash /tests/docker_no_runtime_runner.sh

FROM debian:bookworm-slim

# Install only bare essentials (no runtimes!)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    bash \
    && rm -rf /var/lib/apt/lists/*

# Sanity-check at build time: nothing named node/npm/python3 must be present
RUN ! which node 2>/dev/null && \
    ! which npm  2>/dev/null && \
    ! which python3 2>/dev/null || \
    (echo "ERROR: runtime found in base image" && exit 1)

# The ato binary is injected at runtime via -v mount; no COPY here.
CMD ["bash"]
